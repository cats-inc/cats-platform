# Cats environment template
# Copy to .env for local development.
# Packaged desktop also reads ~/.cats/desktop/.env for desktop-host overrides
# and ~/.cats/platform/config/.env for sidecar-only overrides.

APP_ENV=development
CATS_HOST=127.0.0.1
CATS_PORT=8181
# Desktop host overrides. Keep these on loopback so packaged Electron does not
# inherit LAN-facing binds from CATS_HOST / CATS_RUNTIME_HOST.
CATS_DESKTOP_APP_HOST=127.0.0.1
CATS_DESKTOP_RUNTIME_HOST=127.0.0.1
# Dev web host for Vite (`npm run dev:web` / `npm run preview:web`). Leave blank
# to reuse `CATS_HOST`. Use `0.0.0.0` for same-LAN browser testing.
CATS_WEB_HOST=
# Optional dev/preview ports for the Vite renderer host.
CATS_WEB_DEV_PORT=
CATS_WEB_PREVIEW_PORT=
# Optional proxy target for the Vite renderer host. Leave blank to proxy to the
# local Cats app server on `127.0.0.1:$CATS_PORT`.
CATS_WEB_PROXY_TARGET=
# Defaults to ~/.cats/platform/state/chat-state.local.json when blank.
CATS_PLATFORM_DIR=
CATS_DESKTOP_DIR=
CATS_RUNTIME_DIR=
# Debug-only phase trace for cats-platform cold-start investigation. Writes
# structured startup events to stderr/stdout capture when true.
CATS_PLATFORM_STARTUP_TRACE=false
# Advanced desktop escape hatch. Uncomment to force quit-on-close even if the
# in-app system tray preference is enabled.
# CATS_DESKTOP_FORCE_QUIT_ON_CLOSE=true
# Advanced desktop escape hatch. Set false to force packaged startup audits to
# collect readiness checks serially instead of in parallel.
CATS_DESKTOP_SETUP_AUDIT_PARALLEL=true
# Desktop first-run onboarding policy. Default setup_status shows the packaged
# CLI installer page before /setup when setup is not complete, without blocking
# on CLI inventory. Use cli_inventory_gate to restore the zero-CLI gate.
CATS_DESKTOP_BOOTSTRAP_ONBOARDING_MODE=setup_status
# Mobile pairing is on by default. Set to false to hide Settings > Desktop >
# Mobile pairing entirely and short-circuit `/api/mobile/*`. For same-LAN
# phone access, the desktop app server must bind beyond loopback, for example
# `CATS_DESKTOP_APP_HOST=0.0.0.0` in packaged desktop or `CATS_HOST=0.0.0.0`
# in a built Node run. Re-run `npm run build:mobile:check` after Expo SDK
# bumps before shipping a desktop artifact.
CATS_DESKTOP_MOBILE_PAIRING_ENABLED=true
# Optional dev/package override for the static Expo export root. Leave blank to
# use `build/mobile` in dev and `resources/mobile` in packaged desktop.
CATS_MOBILE_BUNDLE_ROOT=
# Skip the mobile bundle step (`expo export`) inside the desktop installer
# build chain. Useful when the host architecture has no compatible Hermes
# binary (e.g. Linux ARM64 — react-native ships only linux64-bin/hermesc).
# When set to a truthy value (`true`, `1`, `yes`, `on`), the installer runs
# `build:no-mobile` and seeds an empty `build/mobile/.skip-marker`. The
# resulting artifact has no OTA-updatable mobile bundle, so pair this with
# CATS_DESKTOP_MOBILE_PAIRING_ENABLED=false at runtime.
CATS_SKIP_MOBILE=false
# Compatibility aliases: CATS_INC_HOST / CATS_INC_PORT

# Platform authentication (PLAN-089). Auth defaults to enabled for normal
# workspaces. `false` is an unsafe dev/test escape hatch and is rejected after
# setup is complete.
CATS_AUTH_ENABLED=
# Required before creating the first local admin or issuing browser/mobile
# sessions. Use a long random value; tokens are stored only as HMAC hashes.
CATS_AUTH_SESSION_SECRET=
# Browser and Cats Mobile session TTLs in milliseconds.
CATS_AUTH_SESSION_TTL_MS=
CATS_AUTH_MOBILE_SESSION_TTL_MS=
# Local/Google login throttling. Keep these non-empty only when tuning tests or
# deployments with unusual LAN threat models.
CATS_AUTH_LOGIN_FAILURE_LIMIT=
CATS_AUTH_LOGIN_LOCKOUT_MS=
CATS_AUTH_ACCOUNT_DAILY_FAILURE_CAP=
CATS_AUTH_ACCOUNT_COOLDOWN_MS=
CATS_AUTH_SUBNET_DAILY_FAILURE_CAP=
# Comma-separated browser origins allowed to perform pre-auth mutations such as
# setup first-admin creation and local login. Defaults include the app server
# origin plus Vite dev origins. Reverse proxies must preserve the browser's
# Origin header and list their public origin here; Cats does not trust arbitrary
# X-Forwarded-* headers to reconstruct an origin.
CATS_AUTH_ALLOWED_BROWSER_ORIGINS=
# Optional Google identity provider. Browser GIS uses the web client ID.
# Cats Mobile must use explicit mobile audiences.
CATS_AUTH_GOOGLE_CLIENT_ID=
CATS_AUTH_GOOGLE_MOBILE_AUDIENCES=
CATS_AUTH_GOOGLE_HD=

# Runtime boundary
CATS_RUNTIME_BASE_URL=http://127.0.0.1:3110
CATS_RUNTIME_API_KEY=
# Bounded self-healing for stale runtime leases. Set to 0 to disable.
CATS_RUNTIME_STALE_SESSION_RETRY_LIMIT=1
# Debug-only live trace for sequential/runtime stream debugging. Browser trace is
# exposed at window.__catsLiveTrace and server trace at GET /api/debug/live-trace.
CATS_DEBUG_LIVE_TRACE=false
# Debug-only override. Keep this false for normal product behavior so deleting a
# chat / parallel group / cat also deletes linked cats-runtime sessions.
CATS_DEBUG_KEEP_RUNTIME_SESSIONS_ON_PRODUCT_DELETE=false
# Session-create budget (ms) for cats-runtime to bring a provider session up.
# Default 60000. Increase only when investigating slow provider boot.
CATS_RUNTIME_SESSION_CREATE_TIMEOUT_MS=
# Threshold (ms) before logging a slow-session-create warning. Defaults to a
# fraction of the session-create budget; override only for diagnostics.
CATS_RUNTIME_SESSION_CREATE_SLOW_WARNING_MS=
# Idle timeout (ms) for an in-flight runtime stream/turn. Default 120000.
CATS_RUNTIME_MESSAGE_IDLE_TIMEOUT_MS=
# Legacy compound setup timeout (ms). When set, becomes the fallback for both
# CATS_RUNTIME_SETUP_SCAN_PROXY_TIMEOUT_MS and
# CATS_RUNTIME_SETUP_APPLY_PROXY_TIMEOUT_MS below; explicit per-step values
# still win. Leave blank for the explicit defaults.
CATS_RUNTIME_SETUP_PROXY_TIMEOUT_MS=
# Setup wizard proxy scan budget (ms). Default 120000.
CATS_RUNTIME_SETUP_SCAN_PROXY_TIMEOUT_MS=
# Setup wizard proxy apply budget (ms). Default 30000.
CATS_RUNTIME_SETUP_APPLY_PROXY_TIMEOUT_MS=

# Optional override for the provider capability bootstrap YAML path
# (ADR-082 / PLAN-080). Defaults to
# `${platformConfigDir}/provider-capability-bootstrap.yaml` (typically
# `~/.cats/platform/config/provider-capability-bootstrap.yaml`).
CATS_PROVIDER_CAPABILITY_BOOTSTRAP_CONFIG=

# Provider-agent observation/decision flow for chat dispatch (SPEC-082). Default
# false. Turn on to let strong direct Cats produce typed observations and
# tool-request decisions through the per-turn supervisor. Required for the
# `cat_tool` mode of the natural-product-intent gate below.
CATS_CHAT_PROVIDER_AGENT_DECISION_ENABLED=false

# Natural-language Work/Code intent in direct chat (SPEC-105 / ADR-102).
# - off                : default; no no-slash product suggestions. Owners can
#                        always still type explicit /work or /code.
# - cat_tool           : strong direct Cats receive the proposeProductIntake
#                        tool grant and can ask the owner to confirm Work/Code
#                        intake. Pairs with the per-owner profile setting
#                        `naturalProductIntentProposalsEnabled` (defaults to
#                        true so deployments can opt in without per-owner
#                        migration).
# - heuristic_prefilter : experimental v1 PLAN-093 keyword detector backstop.
#                        Detector-only: the proposal tool is NOT exposed in
#                        this mode. Not a default; intended for migration only.
# Effective mode resolution: `off` if either this gate or the owner setting is
# off. Otherwise the effective mode equals this deployment value.
CATS_CHAT_NATURAL_PRODUCT_INTENT_MODE=off

# Cat limits
CATS_MAX_BOSS_CATS=1
CATS_MAX_CATS=5
CATS_MAX_CHAT_PARTICIPANTS=5
# Max audience size for sequential/concurrent group routing.
CATS_MAX_AUDIENCE_PARTICIPANTS=3

# Parallel chat limits
CATS_MAX_PARALLEL_CHATS=3

# Telegram bot integration (optional; only required if you bind a Telegram bot).
# Default Telegram bot token used as the fallback when a bot binding does not
# carry its own token.
CATS_TELEGRAM_BOT_TOKEN=
# Webhook secret token. Telegram is required to send this in
# `X-Telegram-Bot-Api-Secret-Token` for webhook ingress to be accepted; leave
# blank to disable that header check.
CATS_TELEGRAM_WEBHOOK_SECRET=
# Maximum allowed Telegram webhook body size (bytes). Leave blank for the
# library default.
CATS_TELEGRAM_WEBHOOK_MAX_BYTES=

# Optional helper for webhook-mode scripts/windows|linux|macos/*tailscale-funnel*
# Leave blank to use Tailscale's default HTTPS port selection.
TAILSCALE_HTTPS_PORT=

# Optional helper settings for webhook-mode scripts/windows|linux|macos/*ngrok-tunnel*
# If omitted, ngrok falls back to any existing global ngrok CLI configuration.
CATS_NGROK_AUTHTOKEN=
CATS_NGROK_DOMAIN=

# Server startup orchestration (advanced — used by the desktop launcher and
# CLI/integration tests; leave blank for normal local dev).
# Startup mode: `standalone` (default) or `app-managed` when a parent host
# process orchestrates the lifecycle.
CATS_STARTUP_MODE=
# Ready-output format: `plain` (text) or `json`. Defaults to `plain` for
# `standalone` and `json` for `app-managed`.
CATS_READY_OUTPUT=
# Free-form identifier of the parent process managing this server lifecycle.
CATS_MANAGED_BY=
# Override the platform package root used to resolve bundled config example
# paths. Mostly for packaged builds; rarely needed in dev.
CATS_PLATFORM_PACKAGE_ROOT=
