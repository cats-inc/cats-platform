{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "outDir": "./build/desktop",
    "rootDir": "./desktop/host",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "NodeNext",
    "types": ["node"]
  },
  "include": ["desktop/host/**/*.ts", "desktop/host/**/*.cts", "desktop/host/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "build",
    "tests"
  ]
}
