{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022", "DOM"],
    "outDir": "./dist-electron",
    "rootDir": "./electron",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "NodeNext",
    "types": ["node"]
  },
  "include": ["electron/**/*.ts", "electron/**/*.cts", "electron/**/*.d.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "dist-server",
    "dist-electron",
    "tests"
  ]
}
