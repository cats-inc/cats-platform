{
  "name": "@cats-inc/cats-platform",
  "version": "0.1.0",
  "description": "Technical host package for the Cats platform, backed by cats-runtime.",
  "author": "Cats Inc. <sammykenny2@gmail.com>",
  "homepage": "https://github.com/cats-inc/cats-platform",
  "type": "module",
  "bin": {
    "cats-platform": "./dist-server/index.js"
  },
  "main": "dist-electron/main.js",
  "files": [
    "dist",
    "dist-server",
    "dist-electron",
    "scripts",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean:dist && npm run build:server && npm run build:web && npm run build:host",
    "build:host": "tsc -p tsconfig.electron.json",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "build:test-ui": "esbuild tests/*.test.tsx --bundle --platform=node --format=esm --outdir=dist-test",
    "clean:dist": "node scripts/clean-dist.mjs",
    "desktop:host": "electron dist-electron/main.js",
    "desktop:package": "node scripts/build-desktop-installer.mjs --target current",
    "desktop:package:linux": "node scripts/build-desktop-installer.mjs --target linux",
    "desktop:package:macos": "node scripts/build-desktop-installer.mjs --target macos",
    "desktop:package:windows": "node scripts/build-desktop-installer.mjs --target windows",
    "desktop:smoke:linux": "bash ./scripts/linux/test-linux-package-smoke.sh",
    "desktop:smoke:macos": "bash ./scripts/macos/test-macos-package-smoke.sh",
    "desktop:stage": "npm run build && node scripts/package-desktop.mjs --platform all",
    "desktop:stage:linux": "npm run build && node scripts/package-desktop.mjs --platform linux",
    "desktop:stage:macos": "npm run build && node scripts/package-desktop.mjs --platform macos",
    "desktop:stage:windows": "npm run build && node scripts/package-desktop.mjs --platform windows",
    "desktop:start": "npm run build && npm run desktop:host",
    "dev": "npm run dev:web",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "vite",
    "preview:web": "vite preview",
    "prepack": "npm run build",
    "start": "npm run start:server",
    "start:server": "node dist-server/index.js",
    "test": "npm run typecheck && npm run build:server && npm run build:host && npm run build:test-ui && node --test --test-isolation=none tests/**/*.test.js dist-test/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.electron.json && tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "cats",
    "platform",
    "runtime",
    "host"
  ],
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^41.1.1",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.0",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "appId": "io.catsinc.cats",
    "productName": "Cats",
    "extraMetadata": {
      "name": "cats"
    },
    "asar": true,
    "npmRebuild": false,
    "directories": {
      "output": "release",
      "buildResources": "assets/build"
    },
    "files": [
      "dist-electron/**/*",
      "assets/tray-icon.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/desktop-packaging/shared/dist-server",
        "to": "app-sidecar/dist-server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/dist",
        "to": "app-sidecar/dist",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/app-sidecar/package.json",
        "to": "app-sidecar/package.json"
      },
      {
        "from": "build/desktop-packaging/shared/cats-runtime",
        "to": "cats-runtime",
        "filter": [
          "**/*",
          "!node_modules{,/**/*}"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/cats-runtime/node_modules",
        "to": "cats-runtime/node_modules",
        "filter": [
          "**/*",
          "!.bin{,/**/*}"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/setup-assets",
        "to": "desktop-host/setup-assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/desktop-packaging/desktop-package-plan.json",
        "to": "desktop-package-plan.json"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "artifactName": "Cats-${version}-setup-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "pkg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "artifactName": "Cats-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "artifactName": "Cats-${version}-${arch}.${ext}",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    }
  }
}
