{
  "name": "cats-inc",
  "version": "0.1.0",
  "description": "Next-generation cats workspace product backed by cats-runtime.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "npm run build && node dist/index.js",
    "start": "node dist/index.js",
    "test": "npm run build && node --test --test-isolation=none tests/**/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "cats",
    "workspace",
    "runtime",
    "product"
  ],
  "license": "MIT",
  "dependencies": {},
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
