{
  "name": "cats",
  "version": "0.1.0",
  "description": "Flagship Cats suite app backed by cats-runtime.",
  "type": "module",
  "main": "dist-server/index.js",
  "types": "dist-server/index.d.ts",
  "scripts": {
    "build": "npm run build:server && npm run build:web",
    "build:server": "tsc -p tsconfig.server.json",
    "build:web": "vite build",
    "build:test-ui": "esbuild tests/sidebar-my-cats-navigation.test.tsx --bundle --platform=node --format=esm --outfile=dist-test/sidebar-my-cats-navigation.test.mjs",
    "dev": "npm run dev:web",
    "dev:server": "tsx watch src/index.ts",
    "dev:web": "vite",
    "preview:web": "vite preview",
    "start": "node dist-server/index.js",
    "test": "npm run build:server && npm run build:test-ui && node --test --test-isolation=none tests/**/*.test.js dist-test/*.test.mjs",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.json"
  },
  "keywords": [
    "cats",
    "chat",
    "runtime",
    "product"
  ],
  "license": "MIT",
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.13.1"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=22.0.0"
  }
}
