{
  "name": "@cats-inc/cats-platform",
  "version": "0.1.0",
  "description": "Technical host package for the Cats platform, backed by cats-runtime.",
  "author": "Cats Inc. <sammykenny2@gmail.com>",
  "homepage": "https://github.com/cats-inc/cats-platform",
  "type": "module",
  "bin": {
    "cats-platform": "./build/server/index.js"
  },
  "main": "build/desktop/main.js",
  "files": [
    "build/renderer",
    "build/server",
    "build/desktop",
    "scripts",
    "config/provider-capability-bootstrap.yaml.example",
    ".env.example",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "npm run clean:build && node scripts/build-server-artifacts.mjs && npm run build:web && npm run build:mobile && npm run build:host",
    "build:host": "tsc -p tsconfig.desktop.json",
    "build:server": "tsc -p tsconfig.server.json",
    "build:server-bundle": "node scripts/bundle-server.mjs",
    "build:mobile": "npm run mobile:install && npm run mobile:export && node scripts/check-mobile-build.mjs",
    "build:mobile:check": "npm run mobile:install && npm run mobile:typecheck && npm run mobile:export && node scripts/check-mobile-build.mjs",
    "build:no-mobile": "npm run clean:build && node scripts/build-server-artifacts.mjs && npm run build:web && npm run build:host",
    "build:web": "vite build",
    "build:test-ui": "esbuild tests/*.test.tsx --bundle --platform=node --format=esm --outdir=build/test",
    "clean:build": "node scripts/clean-build.mjs",
    "desktop:icons": "node scripts/shared/generate-electron-icons.mjs --input assets/app-icon-silhouette.svg",
    "desktop:host": "electron build/desktop/main.js",
    "desktop:package": "node scripts/build-desktop-installer.mjs --target current",
    "desktop:package:linux": "node scripts/build-desktop-installer.mjs --target linux",
    "desktop:package:macos": "node scripts/build-desktop-installer.mjs --target macos",
    "desktop:package:windows": "node scripts/build-desktop-installer.mjs --target windows",
    "desktop:smoke:linux": "bash ./scripts/linux/test-linux-package-smoke.sh",
    "desktop:smoke:macos": "bash ./scripts/macos/test-macos-package-smoke.sh",
    "desktop:stage": "npm run build && node scripts/package-desktop.mjs --platform all",
    "desktop:stage:linux": "npm run build && node scripts/package-desktop.mjs --platform linux",
    "desktop:stage:macos": "npm run build && node scripts/package-desktop.mjs --platform macos",
    "desktop:stage:windows": "npm run build && node scripts/package-desktop.mjs --platform windows",
    "desktop:start": "npm run build && npm run desktop:host",
    "dev": "npm run dev:web",
    "dev:server": "tsx watch src/index.ts",
    "dev:toggle-flag": "tsx scripts/dev-toggle-feature-flag.mts",
    "dev:web": "vite",
    "ingress:smoke": "node scripts/testing/check-platform-ingress.mjs",
    "preview:bootstrap": "npm run build:host && node scripts/preview-bootstrap.mjs",
    "preview:web": "vite preview",
    "prepack": "npm run build",
    "smoke:live:chat": "tsx --test tests/chat-live-provider-smoke.test.tsx",
    "smoke:live:code": "tsx --test tests/code-live-provider-smoke.test.tsx",
    "smoke:live:providers": "npm run smoke:live:chat && npm run smoke:live:work && npm run smoke:live:code",
    "smoke:live:work": "tsx --test tests/work-live-provider-smoke.test.tsx",
    "start": "npm run start:server",
    "start:server": "node build/server/index.js",
    "test": "npm run typecheck && npm run build:server && npm run build:host && npm run build:test-ui && node --test --test-isolation=none tests/**/*.test.js build/test/*.test.js",
    "typecheck": "tsc --noEmit -p tsconfig.server.json && tsc --noEmit -p tsconfig.desktop.json && tsc --noEmit -p tsconfig.json && npm run mobile:typecheck",
    "mobile:typecheck": "npm run mobile:boundary && npm run typecheck --prefix mobile",
    "mobile:boundary": "node scripts/check-mobile-boundary.mjs",
    "mobile:export": "cd mobile && npx expo export --platform all --output-dir ../build/mobile",
    "mobile:install": "npm ci --prefix mobile && node scripts/patch-mobile-hermesc.mjs"
  },
  "keywords": [
    "cats",
    "platform",
    "runtime",
    "host"
  ],
  "license": "MIT",
  "dependencies": {
    "@tanstack/react-query": "^5.100.6",
    "js-yaml": "^4.1.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^7.14.1"
  },
  "devDependencies": {
    "@fiahfy/icns": "^0.0.7",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^20.0.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "electron": "^41.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "^0.27.0",
    "jsdom": "^24.1.3",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.2",
    "sharp": "^0.34.5",
    "tsx": "^4.21.0",
    "typescript": "^5.0.0",
    "vite": "^7.3.1"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "build": {
    "appId": "io.catsinc.cats",
    "productName": "Cats",
    "extraMetadata": {
      "name": "Cats"
    },
    "asar": true,
    "npmRebuild": false,
    "afterPack": "./scripts/shared/edit-windows-exe-icon.mjs",
    "directories": {
      "output": "release",
      "buildResources": "assets/build"
    },
    "files": [
      "build/desktop/**/*",
      "assets/build/icon.ico",
      "assets/build/icon.png",
      "assets/tray-icon*.png",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "build/desktop-packaging/shared/build/server",
        "to": "app-sidecar/build/server",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/build/renderer",
        "to": "app-sidecar/build/renderer",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/app-sidecar/package.json",
        "to": "app-sidecar/package.json"
      },
      {
        "from": "build/desktop-packaging/shared/app-sidecar/node_modules",
        "to": "app-sidecar/node_modules",
        "filter": [
          "**/*",
          "!.bin{,/**/*}"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/cats-runtime",
        "to": "cats-runtime",
        "filter": [
          "**/*",
          "!node_modules{,/**/*}"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/cats-runtime/node_modules",
        "to": "cats-runtime/node_modules",
        "filter": [
          "**/*",
          "!.bin{,/**/*}"
        ]
      },
      {
        "from": "build/desktop-packaging/shared/setup-assets",
        "to": "desktop/setup-assets",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/mobile",
        "to": "mobile",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "build/desktop-packaging/desktop-package-plan.json",
        "to": "desktop-package-plan.json"
      },
      {
        "from": "build/native",
        "to": "native",
        "filter": [
          "**/*"
        ]
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "icon.ico",
      "signAndEditExecutable": false,
      "artifactName": "Cats-${version}-setup-${arch}.${ext}"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "pkg",
          "arch": [
            "universal"
          ]
        },
        {
          "target": "zip",
          "arch": [
            "universal"
          ]
        }
      ],
      "icon": "icon.icns",
      "artifactName": "Cats-${version}-${arch}.${ext}",
      "category": "public.app-category.productivity",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "extendInfo": {
        "NSSpeechRecognitionUsageDescription": "Cats uses speech recognition for voice input in the chat composer.",
        "NSMicrophoneUsageDescription": "Cats uses the microphone for voice input in the chat composer."
      }
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "tar.gz",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "icons/linux",
      "artifactName": "Cats-${version}-${arch}.${ext}",
      "category": "Utility"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "perMachine": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "installerIcon": "installerIcon.ico",
      "uninstallerIcon": "uninstallerIcon.ico",
      "installerHeaderIcon": "installerHeaderIcon.ico"
    }
  }
}
