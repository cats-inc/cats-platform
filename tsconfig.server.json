{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "lib": ["ES2022"],
    "outDir": "./build/server",
    "rootDir": "./src",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "NodeNext",
    "types": ["node"]
  },
  "include": ["src/**/*.ts"],
  "exclude": [
    "src/renderer/**/*",
    // Renderer entity screens are client-only. Promote pure shared
    // utilities out of this tree before importing them from server code.
    "src/app/renderer/entities/**/*",
    "src/app/renderer/i18n/**/*",
    // Client DOM hook used by renderer shells. Future renderer-only .ts
    // hooks need the same treatment or should live under an excluded tree.
    "src/app/renderer/productShell/useSidebarOverflowMenuDismiss.ts",
    "src/app/renderer/setup/**/*",
    "src/app/renderer/**/*.tsx",
    "src/app/renderer/guideCatPanelDetection.ts",
    "src/products/*/renderer/**/*",
    "node_modules",
    "build",
    "tests"
  ]
}
