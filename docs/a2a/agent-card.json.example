{
  "schema_version": "1.0",
  "agent": {
    "id": "[agent-id]",
    "name": "[Agent Name]",
    "description": "[What this agent does]",
    "owner": "[Team or owner]",
    "contact": {
      "email": "[email@example.com]"
    }
  },
  "capabilities": [
    {
      "id": "[capability-id]",
      "description": "[What this capability does]",
      "inputs": ["[input-1]"],
      "outputs": ["[output-1]"],
      "constraints": ["[constraint-1]"]
    }
  ],
  "interfaces": {
    "a2a_endpoint": "[https://example.com/a2a]",
    "auth": "[OAuth2 / API key / mTLS]"
  },
  "metadata": {
    "version": "[0.1.0]",
    "last_updated": "[YYYY-MM-DD]"
  }
}
