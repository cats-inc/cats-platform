{
  "name": "cats",
  "description": "Pilot public Agent Card example for a future A2A adapter over the Cats suite-host boundary. This example is standards-aligned documentation, not a claim that the current repo already exposes a live A2A endpoint.",
  "supportedInterfaces": [
    {
      "url": "https://cats.example.com/a2a/jsonrpc",
      "protocolBinding": "JSONRPC",
      "protocolVersion": "1.0"
    },
    {
      "url": "https://cats.example.com/a2a/http",
      "protocolBinding": "HTTP+JSON",
      "protocolVersion": "1.0"
    }
  ],
  "provider": {
    "organization": "Cats maintainers",
    "url": "https://example.com/cats"
  },
  "version": "0.1.0-pilot",
  "documentationUrl": "https://example.com/cats/docs/a2a",
  "capabilities": {
    "streaming": true,
    "pushNotifications": false,
    "extendedAgentCard": true
  },
  "securitySchemes": {
    "suiteBearer": {
      "httpAuthSecurityScheme": {
        "description": "Bearer token used when a future A2A adapter is fronted by the same operator/session boundary as protected Cats suite-host routes.",
        "scheme": "Bearer",
        "bearerFormat": "API key or JWT"
      }
    }
  },
  "defaultInputModes": [
    "text/plain",
    "application/json"
  ],
  "defaultOutputModes": [
    "text/plain",
    "application/json"
  ],
  "skills": [
    {
      "id": "suite-reads",
      "name": "Suite Reads",
      "description": "Read suite-host health, operator inbox state, recovery summaries, and product projections without mutating product data.",
      "tags": [
        "product",
        "operators",
        "read-only"
      ],
      "examples": [
        "Summarize the current operator inbox and identify the highest-priority pending action.",
        "Explain the current chat/work/code task posture without mutating runtime or product state."
      ],
      "inputModes": [
        "text/plain",
        "application/json"
      ],
      "outputModes": [
        "text/plain",
        "application/json"
      ]
    },
    {
      "id": "orchestrator-supervision",
      "name": "Orchestrator Supervision",
      "description": "Model future product-side orchestrator planning, dispatch, and recovery handling over the Cats suite boundary.",
      "tags": [
        "orchestration",
        "product",
        "workflow"
      ],
      "examples": [
        "Inspect the current execution-loop checkpoint and explain the next operator-facing decision.",
        "Review a blocked workflow and summarize the safest recovery action."
      ],
      "inputModes": [
        "text/plain",
        "application/json"
      ],
      "outputModes": [
        "text/plain",
        "application/json"
      ]
    }
  ]
}
